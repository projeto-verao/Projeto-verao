# Autenticação OAuth
VITE_APP_ID=seu_app_id_aqui
VITE_OAUTH_PORTAL_URL=https://auth.manus.im

# Banco de Dados
DATABASE_URL=mysql://usuario:senha@localhost:3306/projeto_verao

# Segurança
JWT_SECRET=sua_chave_secreta_super_segura_aqui

# OAuth Server
OAUTH_SERVER_URL=https://api.manus.im

# IA - Gemini
GEMINI_API_KEY=sua_chave_gemini_aqui

# IA - OpenAI (alternativa ao Gemini)
OPENAI_API_KEY=sua_chave_openai_aqui
OPENAI_API_BASE=https://api.openai.com/v1

# YouTube Data API v3 (para busca de vídeos de exercícios)
VITE_YOUTUBE_API_KEY=sua_chave_youtube_api_aqui

# Cloudinary Storage
VITE_CLOUDINARY_CLOUD_NAME=seu_cloud_name_aqui
VITE_CLOUDINARY_UPLOAD_PRESET=seu_upload_preset_aqui

# Ambiente
NODE_ENV=development
PORT=3000

# Owner (para notificações)
OWNER_OPEN_ID=seu_open_id_aqui
