{
  "name": "Projeto Verão",
  "package": "com.projetoverao.app",
  "version": "1.0.0",
  "description": "Aplicativo de geração de treino personalizado por IA com análise visual de composição corporal",
  "author": "Projeto Verão",
  "homepage": "https://3002-i0lxt4bhvb0qsg7qrmnma-41bbb83e.us1.manus.computer",
  "license": "MIT",
  "orientation": "portrait",
  "permissions": [
    "CAMERA",
    "READ_EXTERNAL_STORAGE",
    "WRITE_EXTERNAL_STORAGE",
    "INTERNET",
    "ACCESS_NETWORK_STATE"
  ],
  "features": [
    {
      "name": "android.hardware.camera",
      "required": false
    },
    {
      "name": "android.hardware.camera.autofocus",
      "required": false
    }
  ],
  "icons": {
    "192": "client/public/icon-192.png",
    "512": "client/public/icon-512.png"
  },
  "splashscreen": {
    "image": "client/public/splash.png",
    "image_dark": "client/public/splash-dark.png"
  },
  "statusBarColor": "#000000",
  "statusBarStyle": "light",
  "navigationBarColor": "#000000",
  "theme": "light",
  "usesWebView": true,
  "enableCors": true,
  "enableJavaScript": true,
  "enableLocalStorage": true,
  "enableSessionStorage": true,
  "enableCookies": true,
  "enableGeolocation": false,
  "enableNotifications": true,
  "enableVibration": true,
  "minSdkVersion": 24,
  "targetSdkVersion": 34,
  "compileSdkVersion": 34
}
