rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Funções Auxiliares ──────────────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidWorkout(data) {
      return data.keys().hasAll(['title', 'days', 'isActive', 'version']) &&
             data.title is string &&
             data.days is list &&
             data.isActive is bool &&
             data.version is number;
    }
    
    function isValidBodyProgress(data) {
      return true; // Permitindo os campos do cliente (weightKg, notes, createdAt, etc) temporariamente ou flexível
    }
    
    // ─── Users Collection ────────────────────────────────────────────────────
    
    match /users/{userId} {
      // Usuário pode ler/escrever seus próprios dados
      allow read, write: if isOwner(userId);
      
      // Subcoleções com validações específicas
      match /workouts/{workoutId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWorkout(request.resource.data);
        allow update: if isOwner(userId) && isValidWorkout(request.resource.data);
        allow delete: if isOwner(userId);
      }
      
      match /bodyProgress/{progressId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBodyProgress(request.resource.data);
        allow update: if isOwner(userId) && isValidBodyProgress(request.resource.data);
        allow delete: if isOwner(userId);
      }
      
      match /waterLogs/{logId} {
        allow read, write: if isOwner(userId);
      }
      
      match /meals/{mealId} {
        allow read, write: if isOwner(userId);
      }
      
      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }
      
      match /chatMessages/{messageId} {
        allow read, write: if isOwner(userId);
      }
      match /completions/{completionId} {
        allow read, write: if isOwner(userId);
      }
      match /meta/{metaId} {
        allow read, write: if isOwner(userId);
      }
      match /reminders/{reminderId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ─── Deny Everything Else ───────────────────────────────────────────────
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
